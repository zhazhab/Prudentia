BIND_ADDR=127.0.0.1:8080

# Local config and SQLite state are shared across Git worktrees by default from
# the original repository working tree. Set PRUDENTIA_LOCAL_DIR to override that
# location; relative override paths resolve from the current working directory.
PRUDENTIA_LOCAL_DIR=
DATABASE_URL=sqlite://data/prudentia.sqlite

# AI_PROVIDER=mock keeps the app fully local and deterministic.
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# AI_PROVIDER=cli uses a local AI CLI backend. Codex is the first supported CLI backend.
# Run `codex login --device-auth` first on headless/remote devices.
AI_CLI_PROVIDER=codex
AI_CLI_PATH=codex
AI_CLI_MODEL=
AI_CLI_PROFILE=

# MARKET_DATA_PROVIDER accepts a comma-separated fallback chain.
# Supported entries: mock, yahoo, tencent, longbridge, alpha_vantage.
# yahoo and tencent do not require API keys. Longbridge reads LONGBRIDGE_* credentials.
# Set MARKET_DATA_PROVIDER=alpha_vantage and ALPHA_VANTAGE_API_KEY for Alpha Vantage.
# For real portfolio tracking, use MARKET_DATA_PROVIDER=yahoo,tencent or longbridge,yahoo.
# mock is for offline development and does not update holding or benchmark returns.
MARKET_DATA_PROVIDER=mock
ALPHA_VANTAGE_API_KEY=
LONGBRIDGE_APP_KEY=
LONGBRIDGE_APP_SECRET=
LONGBRIDGE_ACCESS_TOKEN=
PRICE_REFRESH_INTERVAL_SECS=3600
PRICE_REFRESH_TTL_SECS=86400

# Local security symbol directory for draft name-to-symbol matching.
# public uses no-account exchange files; set tushare plus TUSHARE_TOKEN for optional coverage.
SYMBOL_DIRECTORY_PROVIDER=public
SYMBOL_DIRECTORY_PUBLIC_CONFIG=config/symbol-directory-public.json
TUSHARE_TOKEN=
SYMBOL_DIRECTORY_REFRESH_INTERVAL_SECS=86400
