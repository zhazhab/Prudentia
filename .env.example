BIND_ADDR=127.0.0.1:8080
DATABASE_URL=sqlite://data/prudentia.sqlite

# AI_PROVIDER=mock keeps the app fully local and deterministic.
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# AI_PROVIDER=cli uses a local AI CLI backend. Codex is the first supported CLI backend.
# Run `codex login --device-auth` first on headless/remote devices.
AI_CLI_PROVIDER=codex
AI_CLI_PATH=codex
AI_CLI_MODEL=
AI_CLI_PROFILE=

# MARKET_DATA_PROVIDER=mock keeps quotes deterministic.
# Set MARKET_DATA_PROVIDER=alpha_vantage and ALPHA_VANTAGE_API_KEY for real quote refreshes.
MARKET_DATA_PROVIDER=mock
ALPHA_VANTAGE_API_KEY=
PRICE_REFRESH_INTERVAL_SECS=3600
